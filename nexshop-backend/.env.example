# Supabase (WAJIB tetap di .env — dipakai untuk konek ke DB itu sendiri,
# jadi gak bisa disimpan di dalam DB yang sama)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# JWT
JWT_SECRET=

# Brevo (email OTP)
BREVO_API_KEY=
EMAIL_USER=

# URL frontend & backend kamu (dipakai buat returnUrl/cancelUrl/notifyUrl iPaymu).
# WAJIB diisi tanpa trailing slash. Karena sekarang di-deploy sendiri di VPS
# (bukan Railway/Netlify), biasanya frontend & backend satu domain yang sama
# (dibedain lewat path /api/ oleh nginx), contoh:
# FRONTEND_URL=https://nexshop.cloud
# BACKEND_URL=https://nexshop.cloud
FRONTEND_URL=
BACKEND_URL=

# iPaymu — nilai default/fallback. Bisa DIGANTI dari Settings > API Keys
# di admin dashboard tanpa redeploy; .env cuma dipakai kalau tabel api_keys
# masih kosong (fallback awal). Ambil VA & API Key di dashboard iPaymu:
# https://my.ipaymu.com (production) atau https://sandbox.ipaymu.com (testing)
# → menu Integrasi.
IPAYMU_VA=
IPAYMU_API_KEY=
IPAYMU_IS_PRODUCTION=false

# TokoVoucher — sama seperti iPaymu, ini fallback. Ambil Secret Key &
# Member Code di https://member.tokovoucher.net/pengaturan/secret-key
TOKOVOUCHER_MEMBER_CODE=
TOKOVOUCHER_SECRET=
