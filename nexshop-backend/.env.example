# Port backend (PM2/VPS) — Nginx proxy_pass diarahkan ke port ini
PORT=3000

# Supabase (WAJIB tetap di .env — dipakai untuk konek ke DB itu sendiri,
# jadi gak bisa disimpan di dalam DB yang sama)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# JWT
JWT_SECRET=

# Brevo (email OTP)
BREVO_API_KEY=
EMAIL_USER=

# Midtrans — nilai default/fallback. Bisa DIGANTI dari Settings > API Keys
# di admin dashboard tanpa redeploy; .env cuma dipakai kalau tabel api_keys
# masih kosong (fallback awal).
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# TokoVoucher — sama seperti Midtrans, ini fallback. Ambil Secret Key &
# Member Code di https://member.tokovoucher.net/pengaturan/secret-key
TOKOVOUCHER_MEMBER_CODE=
TOKOVOUCHER_SECRET=
